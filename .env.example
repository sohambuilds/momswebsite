# ──────────────────────────────────────────
# SANITY CMS
# ──────────────────────────────────────────
# Create a project at https://www.sanity.io/manage
# Then copy the project ID and dataset name
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# API token — create at sanity.io/manage → API → Tokens
# Needs "Editor" permissions (for writing custom orders)
SANITY_API_TOKEN=your_sanity_api_token

# Webhook secret — used to verify Sanity webhook calls for revalidation
# Generate any random string: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=your_revalidation_secret

# ──────────────────────────────────────────
# RESEND (Email)
# ──────────────────────────────────────────
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=your_resend_api_key

# The email address that receives custom order notifications
NOTIFICATION_EMAIL=suhritaroy@example.com

# ──────────────────────────────────────────
# SITE
# ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
